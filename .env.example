# ==============================================================================
# 짓다 (JITDA) 환경 변수
# 실제 값은 .env.local (dev)  또는 배포 대상의 secrets manager 에 넣는다.
# 절대 커밋하지 않는다. gitleaks 로 감지.
# ==============================================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

# --- Database (Postgres) ---
# 예: postgresql://user:pass@localhost:5432/jitda
DATABASE_URL=postgresql://jitda:jitda@localhost:5432/jitda?schema=public

# --- JWT 서명 키 (256bit 이상, 90일마다 로테이션) ---
# 생성: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-to-32-plus-random-bytes-base64
JWT_REFRESH_SECRET=change-me-to-a-different-32-plus-random-bytes-base64

# 발급 도메인 (JWT iss)
JWT_ISSUER=jitda

# --- Stripe ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- 오브젝트 스토리지 (Cloudflare R2 또는 AWS S3) ---
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=jitda-uploads
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_PUBLIC_CDN_BASE=https://cdn.jitda.com

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM="짓다 <no-reply@jitda.com>"

# --- OAuth (Phase 1: Google / Apple) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Rate limit (Upstash Redis) — 선택 ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry / PostHog — 선택 ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
